# ── Movement chain (frontend reads NEXT_PUBLIC_* at build time) ─────────────
# Fullnode REST API (must end with /v1 where applicable — match Movement docs)

# Testnet (defaults in src/lib/constants.ts if unset)
# NEXT_PUBLIC_MOVEMENT_RPC_URL=https://testnet.movementnetwork.xyz/v1

# Mainnet — set after you deploy; URL must match official Movement mainnet RPC
# NEXT_PUBLIC_MOVEMENT_RPC_URL=https://mainnet.movementnetwork.xyz/v1

# Legacy alias (optional; used only if NEXT_PUBLIC_MOVEMENT_RPC_URL is empty)
# NEXT_PUBLIC_APTOS_API=https://testnet.movementnetwork.xyz/v1

# Account where the fantasy_epl module is published
NEXT_PUBLIC_MODULE_ADDRESS=0xc9f5444ab989c2a7ef73b1eab58b66947c4c5788e25d997d649c7d6ddfbeb5a1

# Module name inside that package (usually fantasy_epl)
NEXT_PUBLIC_MODULE_NAME=fantasy_epl
