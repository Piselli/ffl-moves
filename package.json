{
  "name": "fantasy-epl-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=1 next dev",
    "dev:3001": "WATCHPACK_POLLING=1 next dev -p 3001",
    "dev:lan": "WATCHPACK_POLLING=1 next dev -H 0.0.0.0 -p 3000",
    "build:atlas": "node scripts/build-fpl-photo-atlas.mjs",
    "fpl:gw": "node scripts/fpl-oracle-gw.mjs",
    "move:compile": "bash -lc 'cd move/fantasy-epl-contract && (command -v movement >/dev/null 2>&1 && movement move compile --dev || aptos move compile --dev)'",
    "move:test": "bash -lc 'cd move/fantasy-epl-contract && (command -v movement >/dev/null 2>&1 && movement move test --dev || aptos move test --dev)'",
    "preflight:mainnet": "node scripts/preflight-mainnet.mjs",
    "setup:movement-mainnet-profile": "bash scripts/setup-movement-mainnet-profile.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "5.1.1",
    "@aptos-labs/wallet-adapter-react": "^7.1.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.40.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.2.6",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.383.0",
    "next": "14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "postcss": "^8.4.38",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2"
  }
}
